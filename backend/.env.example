# Copy this to .env and fill in your values

# Required: Set in Railway dashboard
NODE_ENV=production
PORT=8000

# Set to your Vercel frontend URL after deployment (e.g. https://your-app.vercel.app)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional: For Gemini LLM categorization (better accuracy)
GEMINI_API_KEY=

# Optional: For Unsplash image fallback
UNSPLASH_ACCESS_KEY=
